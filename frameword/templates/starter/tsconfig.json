{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@frameword/panels-core": ["./packages/panels-core/src/index.ts"],
      "@frameword/panels-react": ["./packages/panels-react/src/index.tsx"]
    }
  },
  "include": ["src", "packages/*/src"]
}
